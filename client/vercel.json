{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/auth/discord/callback",
      "destination": "/index.html"
    },
    {
      "source": "/api/shop/auth/discord",
      "destination": "https://api.nosdan.store/api/shop/auth/discord"
    },
    {
      "source": "/api/shop/auth/discord-bridge",
      "destination": "https://api.nosdan.store/api/shop/auth/discord-bridge"
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.nosdan.store/api/:path*"
    },
    {
      "source": "/ipn.php",
      "destination": "https://api.nosdan.store/ipn.php"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
