{
  "version": 2,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.nosdan.store/api/$1"
    },
    {
      "source": "/ipn.php",
      "destination": "https://api.nosdan.store/ipn.php"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
